library(dplyr)
# Set the first day of class: "Term begins" date in OHSU academic calendar
first_day = as.Date("3/30/26", "%m/%d/%y")
# Set last day of the class: "Term ends" date in OHSU academic calendar
last_day = as.Date("6/17/26", "%m/%d/%y")
# Create the calendar dates sequence
cal_dates = seq(from = first_day, to = last_day, by = "day")
## Week 1 dates
w1d1 = cal_dates[1]
w1d2 = cal_dates[3]
hw0 = cal_dates[4]
## Week 2 dates
w2d1 = cal_dates[8]
w2d2 = cal_dates[10]
lab1 = cal_dates[14]
## Week 3 dates
w3d1 = cal_dates[15]
w3d2 = cal_dates[17]
hw1 = cal_dates[21]
## Week 4 dates
w4d1 = cal_dates[22]
w4d2 = cal_dates[24]
hw2 = cal_dates[28]
q1_open = cal_dates[24]
q1_close = cal_dates[28]
## Week 5 dates
w5d1 = cal_dates[29]
source("~/Library/CloudStorage/OneDrive-OregonHealth&ScienceUniversity/Teaching/Classes/BSTA_513_26S/BSTA_513_26S_site/class_dates.R")
